{
  "name": "notebooklm-srs-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:watch": "bun --watch run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun run build && bunx playwright test",
    "check": "bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/chrome": "^0.1.37",
    "typescript": "^5.9.3"
  }
}
